{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PLUGIN_ROOT/src/skill_guard/skill-guard_PreToolUse.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PLUGIN_ROOT/src/skill_guard/skill-guard_Stop.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "/\\w+",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PLUGIN_ROOT/src/skill_guard/skill-guard_UserPromptSubmit.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
