{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PLUGIN_ROOT/src/skill_guard/execution_hooks.py\" pre_tool_use_main",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PLUGIN_ROOT/src/skill_guard/execution_hooks.py\" stop_main",
            "timeout": 10
          }
        ]
      }
    ]
  }
}